self.addEventListener('install', (e) => {
  e.waitUntil(
    caches.open('zvideo-cache').then((cache) => {
      return cache.addAll([
        './',
        './index.html',
        // أضف ملفات أخرى مثل CSS، JS، إلخ إذا كانت موجودة
      ]);
    })
  );
});

self.addEventListener('fetch', (e) => {
  e.respondWith(
    caches.match(e.request).then((response) => {
      return response || fetch(e.request);
    })
  );
});
